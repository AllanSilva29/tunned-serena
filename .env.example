# Exemplo de configuração de ambiente para serena_fzf

# Caminho base para buscas de arquivo/padrão (por padrão: current dir '.')
SERENA_FZF_SEARCH_PATH=./

# Editor para abrir arquivos (opcional, padrão: code)
SERENA_FZF_EDITOR=code

# (Opcional) se quiser rodar tasks/serena com um comando alternativo:
SERENA_FZF_SERENA_CMD=serena
